WITH cte AS (
SELECT server_id, 
status_time, 
session_status,
LEAD(status_time) OVER (PARTITION BY server_id ORDER BY status_time, session_status) AS next_time
FROM server_utilization
)
SELECT ROUND(sum(EXTRACT (EPOCH FROM next_time - status_time) / 86400)) AS total_uptime_days
FROM cte
WHERE session_status = 'start'
;

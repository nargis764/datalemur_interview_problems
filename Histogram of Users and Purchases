WITH cte1 AS (
SELECT product_id,
user_id,
transaction_date,
RANK() OVER(PARTITION BY user_id ORDER BY transaction_date DESC) AS order_rank
FROM user_transactions
)
SELECT transaction_date,
user_id,
COUNT(product_id) AS purchase_count
FROM cte1
WHERE order_rank = 1
GROUP BY user_id, transaction_date
ORDER BY transaction_date
